<Window x:Class="XrdRemote.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="320"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="16" Background="#0A0A0A">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="26">
            <StackPanel>
                <TextBlock Text="Settings" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="17" Margin="0,0,0,22"/>

                <TextBlock Text="SERVER PORT" Foreground="#444" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBox x:Name="PortBox" Text="8080" Background="#111111" Foreground="#CCCCCC"
                         BorderBrush="#1A1A1A" BorderThickness="1" Padding="11,9" Margin="0,0,0,20" FontSize="14"
                         FontFamily="Consolas"/>

                <CheckBox x:Name="AutostartCheck" Content="Launch on Windows Startup" Foreground="#888" FontSize="12" Margin="0,0,0,30">
                    <CheckBox.LayoutTransform>
                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                    </CheckBox.LayoutTransform>
                </CheckBox>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Cancel" Grid.Column="0" Click="Cancel_Click" Background="Transparent"
                            Foreground="#555" BorderThickness="0" Cursor="Hand" FontSize="13"/>
                    <Button Content="Apply" Grid.Column="1" Click="Save_Click"
                            Background="White" Foreground="Black" FontWeight="SemiBold" Height="40" Cursor="Hand" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>