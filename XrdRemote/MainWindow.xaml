<Window x:Class="XrdRemote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteXS" Height="540" Width="360"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>

        <Style x:Key="TrafficBtn" TargetType="Button">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}" Width="13" Height="13"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Width="26" Height="26">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C1C1C"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border CornerRadius="14" BorderThickness="0.5" BorderBrush="#252525">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0D0D0D" Offset="0"/>
                <GradientStop Color="#080808" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.7" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" BorderThickness="0,0,0,0.5" BorderBrush="#1C1C1C">
                <Border.Background><SolidColorBrush Color="#0E0E0E"/></Border.Background>
                <Grid Margin="16,0">
                    <!-- macOS traffic lights -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Button Background="#FF5F57" Style="{StaticResource TrafficBtn}" Click="CloseToTray_Click" Margin="0,0,8,0"/>
                        <Button Background="#FEBC2E" Style="{StaticResource TrafficBtn}" Click="Minimize_Click"    Margin="0,0,8,0"/>
                        <Button Background="#28C840" Style="{StaticResource TrafficBtn}" Click="Settings_Click"/>
                    </StackPanel>

                    <!-- Title -->
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold">
                        <Run Text="REMOTE" Foreground="#555"/>
                        <Run Text="XS"     Foreground="#333"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- QR area -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- QR card -->
                <Border Width="210" Height="210" CornerRadius="16" Padding="12" Margin="0,0,0,22">
                    <Border.Background><SolidColorBrush Color="#FFFFFF"/></Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
                    </Border.Effect>
                    <Image x:Name="QrImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <TextBlock Text="SCAN QR TO CONNECT"
                           Foreground="#303030" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,7"/>

                <!-- IP badge -->
                <Border CornerRadius="10" Padding="16,10" Margin="0,0,0,10"
                        BorderThickness="0.5" BorderBrush="#1C1C1C">
                    <Border.Background><SolidColorBrush Color="#111111"/></Border.Background>
                    <TextBlock x:Name="IpText" Text="INITIALIZING..."
                               Foreground="#DDDDDD" FontSize="15"
                               FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>

                <!-- Status -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#30D158" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="7" Color="#30D158" Opacity="0.7" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="Server running · Token secured"
                               Foreground="#383838" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" BorderThickness="0,0.5,0,0" BorderBrush="#1A1A1A">
                <Border.Background><SolidColorBrush Color="#0A0A0A"/></Border.Background>
                <Grid Margin="14,0">
                    <TextBlock x:Name="ClientCountText" Text="No connections"
                               Foreground="#2C2C2C" FontSize="10" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Regenerate token button -->
                        <Button Style="{StaticResource GhostBtn}" Click="RegenerateToken_Click"
                                ToolTip="Regenerate access token (disconnects all clients)">↺</Button>
                        <TextBlock x:Name="VersionText" Text="v2.2"
                                   Foreground="#222" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
