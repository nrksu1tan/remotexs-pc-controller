<Window x:Class="XrdRemote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteXS" Height="520" Width="380"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Border CornerRadius="16" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0F0F0F" CornerRadius="16,16,0,0" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#30D158" Margin="0,0,12,0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#30D158" Opacity="0.5" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="REMOTEXS" Foreground="#CCCCCC" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="ULTRA" Foreground="#444" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="⚙" Width="34" Height="34" Style="{DynamicResource ToolBtn}" Click="Settings_Click"/>
                        <Button Content="—" Width="34" Height="34" Style="{DynamicResource ToolBtn}" Click="Minimize_Click"/>
                        <Button Content="✕" Width="34" Height="34" Style="{DynamicResource CloseBtn}" Click="CloseToTray_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Border Width="240" Height="240" Background="White" CornerRadius="20" Padding="14" Margin="0,0,0,28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.3" ShadowDepth="0"/>
                    </Border.Effect>
                    <Image x:Name="QrImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <TextBlock Text="LOCAL ACCESS POINT" Foreground="#3A3A3A" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Border Background="#111111" CornerRadius="10" Padding="16,12" Margin="40,10,40,5" BorderBrush="#1A1A1A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="IpText" Text="INITIALIZING..." Foreground="#E0E0E0"
                                   FontSize="15" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock x:Name="PinText" Text="PIN: ----" Foreground="#30D158"
                                   FontSize="20" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="ClientCountText" Text="No connections" Foreground="#555555" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#0A0A0A" CornerRadius="0,0,16,16" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0">
                <DockPanel Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="5" Height="5" Fill="#30D158" Margin="0,0,7,0"/>
                        <TextBlock Text="SERVER ACTIVE" Foreground="#3A3A3A" FontSize="9" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock x:Name="VersionText" Text="v2.4" Foreground="#2A2A2A" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>

    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>