<Window x:Class="XrdRemote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteXS" Height="530" Width="360"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Window.Resources>

        <!-- Traffic light button base style -->
        <Style x:Key="TrafficBtn" TargetType="Button">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Width="13" Height="13" Fill="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.78"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Settings icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Setter Property="Foreground" Value="#999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- Main window border -->
    <Border CornerRadius="14" BorderThickness="0.5" BorderBrush="#2A2A2A">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0C0C0C" Offset="0"/>
                <GradientStop Color="#080808" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.65" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" BorderThickness="0,0,0,0.5" BorderBrush="#1E1E1E">
                <Border.Background>
                    <SolidColorBrush Color="#0E0E0E"/>
                </Border.Background>
                <Grid Margin="16,0">
                    <!-- Traffic lights (left) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Button Background="#FF5F57" Style="{StaticResource TrafficBtn}" Click="CloseToTray_Click" Margin="0,0,8,0"/>
                        <Button Background="#FEBC2E" Style="{StaticResource TrafficBtn}" Click="Minimize_Click" Margin="0,0,8,0"/>
                        <Button Background="#28C840" Style="{StaticResource TrafficBtn}" Click="Settings_Click"/>
                    </StackPanel>

                    <!-- App name (center) -->
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold" Foreground="#555">
                        <Run Text="REMOTE"/>
                        <Run Text="XS" Foreground="#333"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- QR area -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- QR card -->
                <Border Width="220" Height="220" CornerRadius="18" Padding="12" Margin="0,0,0,24">
                    <Border.Background>
                        <SolidColorBrush Color="#FFFFFF"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                    </Border.Effect>
                    <Image x:Name="QrImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <!-- IP display -->
                <TextBlock Text="SCAN OR OPEN IN BROWSER"
                           Foreground="#333" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <Border CornerRadius="10" Padding="18,11" Margin="0,0,0,10"
                        BorderThickness="0.5" BorderBrush="#1E1E1E">
                    <Border.Background>
                        <SolidColorBrush Color="#111111"/>
                    </Border.Background>
                    <TextBlock x:Name="IpText" Text="INITIALIZING..."
                               Foreground="#DDDDDD" FontSize="16"
                               FontFamily="Consolas" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Status row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#30D158" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="6" Color="#30D158" Opacity="0.7" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="Server running" Foreground="#444" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" BorderThickness="0,0.5,0,0" BorderBrush="#1A1A1A">
                <Border.Background>
                    <SolidColorBrush Color="#0A0A0A"/>
                </Border.Background>
                <Grid Margin="16,0">
                    <TextBlock Text="RemoteXS PC Server" Foreground="#2E2E2E"
                               FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Text="v2.2"
                               Foreground="#252525" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
